# Required: create a Clerk development application and copy its API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Local database defaults. DATABASE_URL is used when running the app on the host.
MYSQL_DATABASE=ecommerce_admin
MYSQL_USER=ecommerce
MYSQL_PASSWORD=ecommerce
MYSQL_ROOT_PASSWORD=local_root_password
MYSQL_PORT=3306
DATABASE_URL=mysql://ecommerce:ecommerce@localhost:3306/ecommerce_admin

APP_PORT=3000

# Optional: required only for image uploads.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Optional: required only for checkout and payment redirects.
PAYMONGO_SECRET_KEY=
PAYMENT_REDIRECT_SUCCESS=http://localhost:3000
PAYMENT_REDIRECT_CANCELED=http://localhost:3000

# Optional: select a store by Clerk user ID. The first existing store is used otherwise.
SEED_CLERK_USER_ID=
